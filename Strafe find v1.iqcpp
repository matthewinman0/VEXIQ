{"mode":"Text","hardwareTarget":"brain","textContent":"#pragma region VEXcode Generated Robot Configuration\n#include <stdio.h>\n#include <stdlib.h>\n#include <stdbool.h>\n#include <math.h>\n#include <string.h>\n\n#include \"vex.h\"\n\nusing namespace vex;\n\nbrain Brain;\n\n#define waitUntil(condition) do { wait(5, msec); } while (!(condition))\n#define repeat(iterations) for (int iterator = 0; iterator < iterations; iterator++)\n\ninertial BrainInertial = inertial();\n\nmotor leftMotorA = motor(PORT1, 1.3235294117647058, false);\nmotor leftMotorB = motor(PORT2, 1.3235294117647058, false);\nmotor rightMotorA = motor(PORT7, 1.3235294117647058, true);\nmotor rightMotorB = motor(PORT8, 1.3235294117647058, true);\n\nmotor CLAW = motor(PORT4, false);\nmotor ARM = motor(PORT6, false);\n\noptical OpticalSens = optical(PORT3);\ntouchled TouchLED11 = touchled(PORT11);\ndistance Distance12 = distance(PORT12);\n\n// ================= DRIVE =================\n\nvoid stopDrive() {\n  leftMotorA.stop();\n  leftMotorB.stop();\n  rightMotorA.stop();\n  rightMotorB.stop();\n}\n\nvoid driveForward(int speed) {\n  leftMotorA.spin(forward, speed, pct);\n  leftMotorB.spin(forward, speed, pct);\n  rightMotorA.spin(forward, speed, pct);\n  rightMotorB.spin(forward, speed, pct);\n}\n\nvoid driveReverse(int speed) {\n  leftMotorA.spin(reverse, speed, pct);\n  leftMotorB.spin(reverse, speed, pct);\n  rightMotorA.spin(reverse, speed, pct);\n  rightMotorB.spin(reverse, speed, pct);\n}\n\n// X DRIVE STRAFE\nvoid strafeLeft(int speed) {\n  leftMotorA.spin(reverse, speed, pct);\n  leftMotorB.spin(forward, speed, pct);\n  rightMotorA.spin(forward, speed, pct);\n  rightMotorB.spin(reverse, speed, pct);\n}\n\nvoid strafeRight(int speed) {\n  leftMotorA.spin(forward, speed, pct);\n  leftMotorB.spin(reverse, speed, pct);\n  rightMotorA.spin(reverse, speed, pct);\n  rightMotorB.spin(forward, speed, pct);\n}\n\nvoid strafeTime(int dir, int ms, int speed = 40) {\n  if (dir < 0) strafeLeft(speed);\n  else strafeRight(speed);\n\n  wait(ms, msec);\n  stopDrive();\n}\n\n// ================= INIT =================\n\nvoid vexcodeInit() {\n  BrainInertial.calibrate();\n  while (BrainInertial.isCalibrating()) wait(25, msec);\n}\n\n// ================= SEARCH =================\n\nfloat closestDist;\nfloat closestHeading;\nint bestPass;\n\nint findBlock() {\n\n  ARM.spinFor(forward, 160, degrees, true);\n  wait(300, msec);\n\n  float bestDist = 100000;\n  int bestIndex = 0;\n\n  const int steps = 120;        // total scan resolution\n  const int stepTime = 40;     // ms per step\n  const int speed = 50;\n\n  // =========================\n  // MOVE TO FAR LEFT START\n  // =========================\n  strafeLeft(speed);\n  wait(3500, msec); // push fully left edge\n  stopDrive();\n  wait(200, msec);\n\n  // reset position concept\n  int currentIndex = 0;\n\n  // =========================\n  // SCAN RIGHTWARD ONLY\n  // =========================\n  strafeRight(speed);\n\n  for (int i = 0; i < steps; i++) {\n\n    float d = Distance12.objectDistance(mm);\n\n    if (d > 0 && d < bestDist) {\n      bestDist = d;\n      bestIndex = i;\n    }\n\n    currentIndex = i;\n\n    Brain.Screen.clearScreen();\n    Brain.Screen.printAt(10, 20, \"Scan %d/%d\", i, steps);\n    Brain.Screen.printAt(10, 40, \"Dist %.1f\", d);\n\n    wait(stepTime, msec);\n  }\n\n  stopDrive();\n  wait(200, msec);\n\n  // =========================\n  // RETURN TO BEST POSITION\n  // =========================\n  int diff = bestIndex - currentIndex;\n\n  if (diff > 0) {\n    strafeRight(speed + 5);\n    wait(diff * stepTime, msec);\n  } \n  else if (diff < 0) {\n    strafeLeft(speed + 5);\n    wait(-diff * stepTime, msec);\n  }\n\n  stopDrive();\n\n  wait(200, msec);\n\n  // =========================\n  // DRIVE TO BLOCK\n  // =========================\n  while (Distance12.objectDistance(mm) > 50) {\n    driveReverse(50);\n    wait(20, msec);\n  }\n\n  stopDrive();\n\n  TouchLED11.setColor(OpticalSens.color());\n\n  return 0;\n}\n\n// ================= MAIN =================\n\nint main() {\n  vexcodeInit();\n\n  CLAW.spinFor(forward, 60, degrees, false);\n  CLAW.setPosition(0, degrees);\n\n  findBlock();\n\n  Brain.playSound(siren);\n\n  driveReverse(30);\n  wait(500, msec);\n  stopDrive();\n\n  CLAW.spinToPosition(-60, degrees, false);\n  ARM.spinFor(reverse, 160, degrees, true);\n  wait(500, msec);\n  CLAW.spinToPosition(0, degrees, false);\n  ARM.spinFor(forward, 160, degrees, false);\n\n  while (Distance12.objectDistance(mm) > 50) {\n    driveForward(25);\n    wait(20, msec);\n  }\n\n  stopDrive();\n}","textLanguage":"cpp","robotConfig":[{"port":[1,2,7,8,0],"name":"Drivetrain","customName":false,"deviceType":"Drivetrain","deviceClass":"smartdrive","setting":{"type":"4-motor","wheelSize":"200mm","gearRatio":"45:34","direction":"fwd","gyroType":"integrated","width":"173","unit":"mm","wheelbase":"76","wheelbaseUnit":"mm","xOffset":"0","yOffset":"0","thetaOffset":"0"},"triportSourcePort":22},{"port":[4],"name":"CLAW","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse"},"triportSourcePort":22},{"port":[6],"name":"ARM","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse"},"triportSourcePort":22},{"port":[3],"name":"OpticalSens","customName":true,"deviceType":"Optical","deviceClass":"optical","setting":{},"triportSourcePort":22},{"port":[11],"name":"TouchLED11","customName":false,"deviceType":"TouchLED","deviceClass":"touchled","setting":{},"triportSourcePort":22},{"port":[12],"name":"Distance12","customName":false,"deviceType":"Distance","deviceClass":"distance","setting":{},"triportSourcePort":22}],"slot":0,"platform":"IQ","sdkVersion":"20230818.11.00.00","appVersion":"4.67.0","minVersion":"4.60.0","fileFormat":"2.0.0","targetBrainGen":"Second","v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null},"target":"Physical"}